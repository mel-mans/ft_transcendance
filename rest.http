GET {{userUrl}}/me
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

### ============================================
### COMPLETE PROFILE - ERROR CASES
### ============================================

### Missing required fields (should fail)
POST {{userUrl}}/complete-profile
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
Content-Type: application/json

{
  "username": "testuser",
  "name": "Test User"
}

### Username already taken (should fail with 409)
POST {{userUrl}}/complete-profile
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
Content-Type: application/json

{
  "username": "johndoe",
  "name": "Another User",
  "age": 25,
  "location": "Casablanca",
  "moveInDate": "2026-05-01",
  "budget": 6000,
  "currency": "EUR",
  "bio": "Another bio",
  "smoker": false,
  "quietHours": true,
  "earlyBird": false,
  "nightOwl": true,
  "petFriendly": false,
  "cooks": false,
  "gamer": false,
  "social": true,
  "studious": false,
  "clean": true
}

