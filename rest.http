### ============================================
### SETUP: CREATE TEST USER
### ============================================

### 1. Signup
POST {{baseUrl}}/signup
Content-Type: application/json

{
  "email": "profiletest@example.com",
  "password": "Test1234"
}

### 2. Login (copy the access_token)
POST {{baseUrl}}/login
Content-Type: application/json

{
  "identifier": "profiletest@example.com",
  "password": "Test1234"
}

### ============================================
### COMPLETE PROFILE TESTS
### ============================================


### 3. Complete Profile - SUCCESS (all fields)
POST {{userUrl}}/complete-profile
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "username": "testuser123",
  "name": "John Doe",
  "age": 24,
  "sex": "male",
  "bio": "42 student looking for roommate",
  "location": "Casablanca",
  "moveInDate": "2026-04-01",
  "budget": 5000,
  "currency": "MAD",
  "smoker": false,
  "quietHours": true,
  "earlyBird": false,
  "nightOwl": true,
  "petFriendly": true,
  "cooks": true,
  "gamer": true,
  "social": false,
  "studious": true,
  "clean": true
}

### 4. Get Profile (verify complete-profile worked)
GET {{userUrl}}/me
Authorization: Bearer {{token}}

