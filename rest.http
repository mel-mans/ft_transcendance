### ============================================
### COMPLETE WORKFLOW TEST
### ============================================

### 23. WORKFLOW: Create → Complete → Update → Verify

# Step 1: Create new user
POST {{baseUrl}}/signup
Content-Type: application/json

{
  "email": "workflow@example.com",
  "password": "Test1234"
}

###
# Step 2: Login
POST {{baseUrl}}/login
Content-Type: application/json

{
  "identifier": "workflow@example.com",
  "password": "Test1234"
}

###
# Step 3: Complete profile (paste token from step 2)
POST {{userUrl}}/complete-profile
Authorization: Bearer PASTE_TOKEN_HERE
Content-Type: application/json

{
  "username": "workflow_user",
  "name": "Workflow Test",
  "age": 22,
  "sex": "female",
  "bio": "Testing complete workflow",
  "location": "Marrakech",
  "moveInDate": "2026-07-01",
  "budget": 4500,
  "currency": "MAD",
  "smoker": false,
  "quietHours": true,
  "earlyBird": true,
  "nightOwl": false,
  "petFriendly": true,
  "cooks": true,
  "gamer": false,
  "social": true,
  "studious": true,
  "clean": true
}

###
# Step 4: Update some fields
PATCH {{userUrl}}/profile
Authorization: Bearer PASTE_TOKEN_HERE
Content-Type: application/json

{
  "bio": "Updated workflow bio",
  "budget": 5500
}

###
# Step 5: Verify final state
GET {{userUrl}}/me
Authorization: Bearer PASTE_TOKEN_HERE

